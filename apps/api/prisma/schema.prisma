datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum Tier {
  PLEBIAN
  CITIZEN
  PATRICIAN
  TYCOON
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum ContentType {
  TEXT
  PHOTO
  POLL
}

enum InteractionType {
  UPVOTE
  DOWNVOTE
  VIEW
  SHARE
  BOOKMARK
  RESHARE
}

enum NotificationType {
  LIKE
  COMMENT
  FOLLOW
  RESHARE
  MENTION
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(uuid())
  username        String    @unique
  email           String?   @unique
  phoneNumber     String?   @unique
  passwordHash    String?

  fullName        String?
  avatar          String?
  bio             String?

  tier            Tier      @default(PLEBIAN)
  county          String?
  gender          Gender?
  dateOfBirth     DateTime?
  country         String    @default("Kenya")

  profileComplete Boolean   @default(false)
  isVerified      Boolean   @default(false)
  isBanned        Boolean   @default(false)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  lastActiveAt    DateTime?

  // Social graph
  followers       Follow[]  @relation("Followed")
  following       Follow[]  @relation("Follower")
  blocks          Block[]   @relation("Blocker")
  blockedBy       Block[]   @relation("Blocked")

  // Content
  posts           Post[]
  comments        Comment[]
  interactions    UserInteraction[]

  // Notifications
  notifications         Notification[] @relation("NotificationRecipient")
  sentNotifications     Notification[] @relation("NotificationSender")

  // Stories
  fires           Fire[]

  // Kao Listings
  kaoListings    KaoListing[]

  // Marketplace
  sellerProfile       SellerProfile?
  marketListings      MarketListing[]
  marketBuyOrders     MarketOrder[]   @relation("MarketBuyer")
  marketSellOrders    MarketOrder[]   @relation("MarketSeller")
  marketReviewsGiven  MarketReview[]  @relation("ReviewAuthor")
  marketReviewsReceived MarketReview[] @relation("ReviewTarget")
  marketReports       MarketReport[]  @relation("ReportAuthor")
}

// ─── Follow / Block ───────────────────────────────────────────────────────────

model Follow {
  followerId  String
  followedId  String
  createdAt   DateTime @default(now())

  follower    User @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  followed    User @relation("Followed", fields: [followedId], references: [id], onDelete: Cascade)

  @@id([followerId, followedId])
}

model Block {
  blockerId   String
  blockedId   String
  createdAt   DateTime @default(now())
  reason      String?

  blocker     User @relation("Blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked     User @relation("Blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@id([blockerId, blockedId])
}

// ─── Post ─────────────────────────────────────────────────────────────────────

model Post {
  id           String      @id @default(uuid())
  content      String
  imageUrl     String?
  contentType  ContentType @default(TEXT)
  isPinned     Boolean     @default(false)
  isDeleted    Boolean     @default(false)
  viewCount    Int         @default(0)

  authorId     String
  author       User        @relation(fields: [authorId], references: [id], onDelete: Cascade)

  comments     Comment[]
  interactions UserInteraction[]

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([authorId])
  @@index([createdAt(sort: Desc)])
}

// ─── Comment ──────────────────────────────────────────────────────────────────

model Comment {
  id        String    @id @default(uuid())
  content   String
  isDeleted Boolean   @default(false)

  authorId  String
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  postId    String
  post      Post      @relation(fields: [postId], references: [id], onDelete: Cascade)

  parentId  String?
  parent    Comment?  @relation("Replies", fields: [parentId], references: [id])
  replies   Comment[] @relation("Replies")

  interactions UserInteraction[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([postId])
}

// ─── User Interaction ─────────────────────────────────────────────────────────

model UserInteraction {
  id        String          @id @default(uuid())
  type      InteractionType
  userId    String
  postId    String?
  commentId String?

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, postId, type])
  @@unique([userId, commentId, type])
  @@index([userId])
  @@index([postId])
}

// ─── Notification ─────────────────────────────────────────────────────────────

model Notification {
  id          String           @id @default(uuid())
  type        NotificationType
  isRead      Boolean          @default(false)

  recipientId String
  recipient   User   @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)

  senderId    String?
  sender      User?  @relation("NotificationSender", fields: [senderId], references: [id], onDelete: SetNull)

  postId      String?
  commentId   String?

  createdAt   DateTime @default(now())

  @@index([recipientId, isRead])
}

// ─── Fire (Stories) ───────────────────────────────────────────────────────────

model Fire {
  id        String   @id @default(uuid())
  mediaUrl  String?
  content   String?
  expiresAt DateTime

  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([authorId])
  @@index([expiresAt])
}

// ─── Kao (Real Estate) ────────────────────────────────────────────────────────

enum ListingType {
  RENTAL
  ROOMMATE
}

model KaoListing {
  id           String      @id @default(uuid())
  title        String
  description  String
  type         String      // Bedsitter, 1BR, 2BR, etc.
  listingType  ListingType @default(RENTAL)
  price        Float
  county       String
  area         String
  lat          Float?      // To support Leaflet Map Pins
  lng          Float?
  images       String[]    // Array of URLs
  tags         String[]    // wifi, deposit to include
  vacantCount  Int         @default(1)
  isVerified   Boolean     @default(false)
  
  authorId     String
  author       User        @relation(fields: [authorId], references: [id], onDelete: Cascade)

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([authorId])
  @@index([county, area])
  @@index([createdAt(sort: Desc)])
}

// ─── Marketplace ──────────────────────────────────────────────────────────────

enum MarketCategory {
  ELECTRONICS
  FASHION
  VEHICLES
  FURNITURE
  SERVICES
  BEAUTY
  BOOKS
  SPORTS
  HOME_GARDEN
  OTHER
}

enum TradeType {
  SELL
  BARTER
  BOTH
}

enum ItemCondition {
  NEW
  LIKE_NEW
  GOOD
  FAIR
  FOR_PARTS
}

enum OrderStatus {
  PENDING
  PAID
  ESCROW_HELD
  IN_TRANSIT
  DELIVERED
  DISPUTED
  REFUNDED
  COMPLETED
}

model SellerProfile {
  id              String    @id @default(uuid())
  storeName       String
  bio             String?
  logo            String?
  banner          String?
  isVerified      Boolean   @default(false)
  responseRate    Float     @default(0)
  completedDeals  Int       @default(0)
  safetyScore     Float     @default(50) // 0-100

  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  listings        MarketListing[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model MarketListing {
  id              String          @id @default(uuid())
  title           String
  description     String
  price           Float
  category        MarketCategory  @default(OTHER)
  tradeType       TradeType       @default(SELL)
  barterFor       String?         // What they'd accept in trade
  condition       ItemCondition   @default(GOOD)
  county          String
  area            String
  images          String[]
  tags            String[]
  flagCount       Int             @default(0)
  isActive        Boolean         @default(true)

  sellerId        String
  seller          User            @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  sellerProfileId String?
  sellerProfile   SellerProfile?  @relation(fields: [sellerProfileId], references: [id])

  orders          MarketOrder[]
  reviews         MarketReview[]
  reports         MarketReport[]

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([sellerId])
  @@index([county, category])
  @@index([createdAt(sort: Desc)])
}

model MarketOrder {
  id              String       @id @default(uuid())
  amount          Float
  escrowHeld      Boolean      @default(false)
  status          OrderStatus  @default(PENDING)
  deliveryCode    String?      // Code driver uses to confirm delivery
  saccoName       String?
  driverName      String?
  driverPhone     String?

  buyerId         String
  buyer           User         @relation("MarketBuyer", fields: [buyerId], references: [id], onDelete: Cascade)

  sellerId        String
  seller          User         @relation("MarketSeller", fields: [sellerId], references: [id], onDelete: Cascade)

  listingId       String
  listing         MarketListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  review          MarketReview?

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([buyerId])
  @@index([sellerId])
}

model MarketReview {
  id          String   @id @default(uuid())
  rating      Int      // 1-5
  comment     String?

  fromUserId  String
  fromUser    User     @relation("ReviewAuthor", fields: [fromUserId], references: [id], onDelete: Cascade)

  toUserId    String
  toUser      User     @relation("ReviewTarget", fields: [toUserId], references: [id], onDelete: Cascade)

  listingId   String
  listing     MarketListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  orderId     String   @unique
  order       MarketOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([toUserId])
}

model MarketReport {
  id          String   @id @default(uuid())
  reason      String
  details     String?
  resolved    Boolean  @default(false)

  reporterId  String
  reporter    User     @relation("ReportAuthor", fields: [reporterId], references: [id], onDelete: Cascade)

  listingId   String
  listing     MarketListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@index([listingId])
}

